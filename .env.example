# Copy to .env and fill in. NEVER commit the real .env.
SUPABASE_URL=https://xzxqqtizascjsbcrtcha.supabase.co
SUPABASE_KEY=            # service_role key (Supabase → Settings → API)
SUPABASE_ANON_KEY=       # public anon key — used by the built-in dashboard in the browser
PORT=3000

# ---- Gemini AI (recommended) ----
# Get a free API key from https://aistudio.google.com/apikey
# Without this, the bot falls back to numbered menu + FAQ keyword matching.
GEMINI_API_KEY=
# Optional: override the default model (default tries gemini-2.5-flash → 2.0-flash → 1.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ---- Dashboard login ----
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=ChangeMe-8842

# PUPPETEER_EXECUTABLE_PATH is set inside the Docker image automatically.
